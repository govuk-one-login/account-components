{
  "$schema": "https://raw.githubusercontent.com/govuk-one-login/quality-gates/refs/tags/v0.1.0/schemas/schema.json",
  "services": [
    {
      "service-tag": "home",
      "quality-gates": [
        {
          "check-types": ["unit", "new feature", "regression"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/local-tests-unit.yaml",
            "path": "jobs.local-tests-unit",
            "name": "Local tests (unit)"
          }
        },
        {
          "check-types": [
            "code style and linting",
            "vulnerability detection",
            "code quality",
            "secret scanning"
          ],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/lint.yaml",
            "path": "jobs.lint",
            "name": "Lint"
          }
        },
        {
          "check-types": ["integration", "accessibility", "regression"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/local-tests-integration.yaml",
            "path": "jobs.local-tests-integration",
            "name": "Local tests (integration)"
          }
        },
        {
          "check-types": ["integration", "accessibility", "regression"],
          "provider": "Stack Orchestrator",
          "phase": "build",
          "config": {
            "file": ".github/workflows/deploy.yaml",
            "path": "jobs.publish-integration-tests-image",
            "name": "Integration test"
          }
        },
        {
          "check-types": ["code quality", "unit test coverage"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/sonarcloud.yaml",
            "path": "jobs.sonarcloud",
            "name": "SonarCloud"
          }
        },
        {
          "check-types": ["canary"],
          "provider": "Stack Orchestrator",
          "phase": "integration",
          "config": {
            "file": ".github/workflows/deploy.yaml",
            "path": "jobs.deploy",
            "name": "Deploy"
          }
        },
        {
          "check-types": ["canary"],
          "provider": "Stack Orchestrator",
          "phase": "production",
          "config": {
            "file": ".github/workflows/deploy.yaml",
            "path": "jobs.deploy",
            "name": "Deploy"
          }
        },
        {
          "check-types": ["unit", "new feature", "regression"],
          "provider": "GitHub",
          "phase": "pre-upload",
          "config": {
            "file": ".github/workflows/local-tests-unit.yaml",
            "path": "jobs.local-tests-unit",
            "name": "Local tests (unit)"
          }
        }
      ]
    }
  ]
}
