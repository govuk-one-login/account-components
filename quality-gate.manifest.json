{
  "$schema": "https://raw.githubusercontent.com/govuk-one-login/quality-gates/refs/tags/v0.4.0/schemas/schema.json",
  "services": [
    {
      "service-tag": "home",
      "quality-gates": [
        {
          "check-types": ["unit", "new feature", "regression"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/test.yaml",
            "path": "jobs.test",
            "name": "Test"
          }
        },
        {
          "check-types": ["code style and linting", "vulnerability detection"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/check.yaml",
            "path": "jobs.check",
            "name": "Check"
          }
        },
        {
          "check-types": ["component", "integration", "accessibility", "regression"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/integration-test.yaml",
            "path": "jobs.integration-test",
            "name": "Integration test"
          }
        },
        {
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/sonarcloud.yaml",
            "path": "jobs.sonarcloud",
            "name": "SonarCloud"
          }
        }
      ]
    }
  ]
}
