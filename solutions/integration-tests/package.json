{
  "name": "integration-tests",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.11.1 <25"
  },
  "scripts": {
    "run:all": "cd ../../ && export IS_INTEGRATION_TEST=1; npm run run:all",
    "build": "docker build -t account-components-integration-test .",
    "install-browsers": "playwright install --with-deps chromium",
    "start-test-server": "npm run build && docker run --network=host --rm --init account-components-integration-test run-server",
    "watch": "nodemon -w ./tests -w ./utils -w ./.env.ts -w ./.env -e \"*\" --exec \"bddgen\"",
    "test": "npm ci && bddgen && playwright test",
    "test:update-snapshots": "bash update-snapshots.sh",
    "test:ui": "npm ci && run-p test:ui:*",
    "test:ui:watch": "npm run watch",
    "test:ui:run": "playwright test --ui",
    "audit": "npm audit --audit-level=moderate && npm audit signatures"
  },
  "devDependencies": {
    "@aws-lambda-powertools/parameters": "^2.33.0",
    "@aws-sdk/client-ssm": "^3.1038.0",
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "devtools-protocol": "^0.0.1621552",
    "dotenv": "^17.4.2",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "playwright-bdd": "^8.5.0",
    "valibot": "^1.3.1",
    "yaml": "^2.8.3"
  }
}
